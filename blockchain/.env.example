# Copy to `.env` in this directory (`blockchain/`). `script/common.sh` loads `.env` when present.
# Used by: `bash script/deploy.sh` ‚Üí `script/common.sh` ‚Üí `forge script script/FundsDistributor.s.sol:WorcadianScript`

# -----------------------------------------------------------------------------
# FundsDistributor.s.sol ‚Äî passed into `initialize` for all three roles today
# -----------------------------------------------------------------------------
# Address of the account that will broadcast (should match the key or Ledger account below).
DEPLOYER_ADDRESS=0x0000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# script/common.sh ‚Äî network
# -----------------------------------------------------------------------------
# `1` = Immutable zkEVM mainnet; anything else (e.g. `0`) = Immutable zkEVM testnet.
USE_MAINNET=0

# -----------------------------------------------------------------------------
# script/common.sh ‚Äî Blockscout contract verification
# -----------------------------------------------------------------------------
# Appended to BLOCKSCOUT_URI as the verifier URL query suffix (see common.sh).
BLOCKSCOUT_APIKEY=

# -----------------------------------------------------------------------------
# script/common.sh ‚Äî signer (set ONE path: private key XOR Ledger)
# -----------------------------------------------------------------------------
# `0` = use PRIVATE_KEY; `1` = use Ledger (--ledger, --hd-paths).
USE_LEDGER=0

# Raw hex private key of the broadcaster (no echo in common.sh). Required when USE_LEDGER=0.
PRIVATE_KEY=

# BIP32/BIP44 HD path for Ledger. Required when USE_LEDGER=1.
# Example: m/44'/60'/0'/0/0
LEDGER_HD_PATH=
